# —— ConvertKit (Kit) — server-only; never expose in client code ——
CONVERTKIT_API_KEY=

# Optional: one default form for local dev if per-intent forms are not set
CONVERTKIT_DEFAULT_FORM_ID=

# Per-intent ConvertKit form IDs (numeric). Configure automations/tags on each form in Kit.
CONVERTKIT_FORM_LOVE_RESET=
CONVERTKIT_FORM_INTENTIONAL_SPACE=
CONVERTKIT_FORM_CT_COLLAB=
CONVERTKIT_FORM_FOREVER_DAY=
CONVERTKIT_FORM_FOREVER_TABLE=
CONVERTKIT_FORM_CIRCLE=
CONVERTKIT_FORM_SPEAKING=
CONVERTKIT_FORM_GENERAL=
CONVERTKIT_FORM_NEWSLETTER=

# Optional: tag subscribe by numeric ID (see Kit dashboard). Env key pattern:
# CONVERTKIT_TAG_ID_LOVE_RESET, CONVERTKIT_TAG_ID_CT_COLLAB, etc.

# —— Public URLs (safe for browser) ——
NEXT_PUBLIC_TICKET_CANDY_URL=
NEXT_PUBLIC_SUBSTACK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
